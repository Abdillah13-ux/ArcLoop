{
  "name": "arcloop",
  "version": "0.1.0",
  "private": true,
  "description": "ArcLoop is a mobile-first rotating USDC savings pool on Arc.",
  "license": "MIT",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "format": "prettier --check .",
    "dev:api": "pnpm --filter @arcloop/api dev",
    "dev:mobile": "pnpm --filter @arcloop/mobile dev",
    "contracts:build": "cd contracts && forge build",
    "contracts:test": "cd contracts && forge test"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
